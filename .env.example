# ── PitWall Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local for local development
# In Vercel: Settings → Environment Variables → add these

# Your Anthropic API key (get one at console.anthropic.com)
# NEVER commit the real key to git — only this .example file
ANTHROPIC_API_KEY=sk-ant-api03-...

# Your deployed Vercel domain — used for CORS (optional, * allows all)
# Example: https://pitwall-f1.vercel.app
ALLOWED_ORIGIN=*
